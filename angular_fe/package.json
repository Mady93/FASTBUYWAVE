{
  "name": "angular-fe",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:angular_fe": "node dist/angular_fe/server/server.mjs",
    "docs": "rmdir /s /q docs & typedoc",
    "docs:watch": "typedoc --watch",
    "docs:open": "start docs/index.html",
    "docs:serve": "npx http-server docs -p 8090",
    "start:fritz": "dotenv -e .env.local -- ng serve --configuration development --allowed-hosts localhost,%FRITZ_HOST% --open",
    "clean": "ng cache clean"
  },
  "private": true,
  "dependencies": {
