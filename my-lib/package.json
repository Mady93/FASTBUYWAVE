{
  "name": "my-lib",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "build": "ng build my-lib-inside",
    "build:watch": "ng build my-lib-inside --watch",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "cache:clean": "ng cache clean && npm cache clean --force",
    "docs": "xcopy /Y graphs\\lib-dependency-graph.svg projects\\my-lib-inside\\ & mkdir docs\\projects\\my-lib-inside 2>nul & xcopy /Y projects\\my-lib-inside\\package.json docs\\projects\\my-lib-inside\\ & npx typedoc & xcopy /Y LICENSE docs\\ & del projects\\my-lib-inside\\lib-dependency-graph.svg",
    "docs:serve": "npx http-server docs -p 8888",
    "docs:clean": "rmdir /s /q docs",
    "graph:generate": "node generate-lib-graph.mjs",
    "graph:export": "mmdc -i graphs/lib-dependency-graph.mmd -o graphs/lib-dependency-graph.svg -w 4000 -H 3000",
    "graph:clean": "del graphs\\lib-dependency-graph.md graphs\\lib-dependency-graph.mmd graphs\\lib-dependency-graph.svg"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.1.0",
    "@angular/cdk": "^18.2.7",
    "@angular/common": "^18.1.0",
    "@angular/compiler": "^18.1.0",
    "@angular/core": "^18.1.0",
    "@angular/forms": "^18.1.0",
    "@angular/material": "^18.2.7",
    "@angular/platform-browser": "^18.1.0",
    "@angular/platform-browser-dynamic": "^18.1.0",
    "@angular/router": "^18.1.0",
    "@fortawesome/angular-fontawesome": "^0.15.0",
    "@fortawesome/fontawesome-common-types": "^6.6.0",
    "@fortawesome/fontawesome-free": "^6.6.0",
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "bootstrap": "^5.3.3",
    "my-lib-inside": "file:projects/my-lib-inside",
    "popper.js": "^1.16.1",
    "primeng": "^17.18.11",
    "rxjs": "~7.8.0",
    "swiper": "^12.1.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.1.0",
    "@angular/cli": "^18.1.3",
    "@angular/compiler-cli": "^18.1.0",
    "@angular/localize": "^18.2.5",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^18.2.0",
    "typedoc": "^0.28.17",
    "typedoc-rhineai-theme": "^1.2.0",
    "typescript": "~5.5.2"
  }
}
